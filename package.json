{
  "name": "desktop-editor",
  "version": "1.0.2",
  "description": "Modern text and JSON editor with Electron",
  "homepage": "https://github.com/Dnyaneshwar432/Destop_Code_Editor#readme",

  "bugs": {
    "url": "https://github.com/Dnyaneshwar432/Destop_Code_Editor/issues"
  },

  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dnyaneshwar432/Destop_Code_Editor.git"
  },

  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "main.js",

  "scripts": {
    "start": "electron . --no-sandbox",
    "build": "electron-builder",
    "dist": "electron-builder --publish=never",
    "release": "electron-builder --publish=always"
  },

 

  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^26.8.1"
  },

  "build": {
    "appId": "com.desktop.editor",
    "productName": "Desktop Editor",

    "directories": {
      "output": "dist"
    },

    "files": [
      "**/*",
      "!node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!node_modules/*.d.ts",
      "!node_modules/.bin",
      "!**/*.map"
    ],

    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },

    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    },

    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },

    "publish": {
      "provider": "github",
      "owner": "Dnyaneshwar432",
      "repo": "Destop_Code_Editor"
    }
  }
}